<?xml version="1.0"?>
<robot name="hdr_robot" xmlns:xacro="http://ros.org/wiki/xacro">
  <material name="ivory">
    <color rgba="1.0 0.945 0.773 1.0" />
  </material>
  <material name="black">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="gray">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>
  <xacro:property name="mesh_scale" value="0.001" />
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="file://$(find hdr_description)/meshes/robots/hdr35_20/visual/base_body.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
      <material name="ivory"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="file://$(find hdr_description)/meshes/robots/hdr35_20/collision/base_body.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="118.90"/>
      <origin xyz="0.0 0 0.1" rpy="0 0 0"/>
      <inertia ixx="2.7198" ixy="0.0" ixz="0.0" iyy="4.4954" iyz="0.0" izz="6.3413"/>
    </inertial>
  </link>
  <link name="lower_frame_link">
    <visual>
      <geometry>
        <mesh filename="file://$(find hdr_description)/meshes/robots/hdr35_20/visual/lower_frame.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
      <material name="ivory"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="file://$(find hdr_description)/meshes/robots/hdr35_20/collision/lower_frame.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="147.17"/>
      <origin xyz="0.0 0 0.2" rpy="0 0 0"/>
      <inertia ixx="7.5400" ixy="0.0" ixz="0.0" iyy="8.1593" iyz="0.0" izz="6.2706"/>
    </inertial>
  </link>
  <link name="upper_frame_link">
    <visual>
      <geometry>
        <mesh filename="file://$(find hdr_description)/meshes/robots/hdr35_20/visual/upper_frame.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
      <material name="ivory"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="file://$(find hdr_description)/meshes/robots/hdr35_20/collision/upper_frame.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="68.63"/>
      <origin xyz="0.0 0.0 -0.04" rpy="0 0 0"/>
      <inertia ixx="7.9244" ixy="0.0" ixz="0.0" iyy="0.7434" iyz="0.0" izz="8.2104"/>
    </inertial>
  </link>
  <link name="arm_link">
    <visual>
      <geometry>
        <mesh filename="file://$(find hdr_description)/meshes/robots/hdr35_20/visual/arm.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
      <material name="ivory"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="file://$(find hdr_description)/meshes/robots/hdr35_20/collision/arm.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="73.93"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1.7700" ixy="0.0" ixz="0.0" iyy="6.6691" iyz="0.0" izz="7.1773"/>
    </inertial>
  </link>
  <link name="wrist_body_link">
    <visual>
      <geometry>
        <mesh filename="file://$(find hdr_description)/meshes/robots/hdr35_20/visual/wrist_body.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
      <material name="ivory"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="file://$(find hdr_description)/meshes/robots/hdr35_20/collision/wrist_body.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="20.15"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0706" ixy="0.0" ixz="0.0" iyy="0.1553" iyz="0.0" izz="0.1601"/>
    </inertial>
  </link>
  <link name="wrist_holder_link">
    <visual>
      <geometry>
        <mesh filename="file://$(find hdr_description)/meshes/robots/hdr35_20/visual/wrist_holder.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
      <material name="ivory"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="file://$(find hdr_description)/meshes/robots/hdr35_20/collision/wrist_holder.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="11.26"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0800" ixy="0.0" ixz="0.0" iyy="0.1130" iyz="0.0" izz="0.0938"/>
    </inertial>
  </link>
  <link name="flange_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find hdr_description)/meshes/robots/hdr35_20/visual/flange.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find hdr_description)/meshes/robots/hdr35_20/collision/flange.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
    </collision>
    <inertial>
      <!-- <mass value="0.1"/> -->
      <mass value="0.79"/>
      <origin xyz="0.005 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0022" ixy="0.0" ixz="0.0" iyy="0.0011" iyz="0.0" izz="0.0011"/>
    </inertial>
  </link>
  <link name="motor_s">
    <visual>
      <geometry>
        <mesh filename="file://$(find hdr_description)/meshes/robots/hdr35_20/visual/motor_s.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="file://$(find hdr_description)/meshes/robots/hdr35_20/collision/motor_s.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>
  <link name="motor_h">
    <visual>
      <geometry>
        <mesh filename="file://$(find hdr_description)/meshes/robots/hdr35_20/visual/motor_h.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="file://$(find hdr_description)/meshes/robots/hdr35_20/collision/motor_h.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>
  <link name="motor_v">
    <visual>
      <geometry>
        <mesh filename="file://$(find hdr_description)/meshes/robots/hdr35_20/visual/motor_v.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="file://$(find hdr_description)/meshes/robots/hdr35_20/collision/motor_v.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <joint name="j1" type="revolute">
    <parent link="base_link"/>
    <child link="lower_frame_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.141" upper="3.141" effort="3078.7" velocity="3.141"/>
  </joint>
  <joint name="j2" type="revolute">
    <parent link="lower_frame_link"/>
    <child link="upper_frame_link"/>
    <origin xyz="0.15 0.08 0.56" rpy="0 1.5708 -1.5708"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.785" upper="3.141" effort="3169.7" velocity="3.141"/>
  </joint>
  <joint name="j3" type="revolute">
    <parent link="upper_frame_link"/>
    <child link="arm_link"/>
    <origin xyz="0 0.87 -0.04" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.396" upper="3.141" effort="1507.0" velocity="3.316"/>
  </joint>
  <joint name="j4" type="revolute">
    <parent link="arm_link"/>
    <child link="wrist_body_link"/>
    <origin xyz="0.828 0.175 0.1415" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-6.283" upper="6.283" effort="259.0" velocity="5.410"/>
  </joint>
  <joint name="j5" type="revolute">
    <parent link="wrist_body_link"/>
    <child link="wrist_holder_link"/>
    <origin xyz="0.195 0.0 0.04" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.181" upper="2.181" effort="240.4" velocity="5.410"/>
  </joint>
  <joint name="j6" type="revolute">
    <parent link="wrist_holder_link"/>
    <child link="flange_link"/>
    <origin xyz="0.175 0 -0.0375" rpy="-1.5708 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-6.283" upper="6.283" effort="215.6" velocity="7.330"/>
  </joint>

  <joint name="joint_motor_s" type="fixed">
    <parent link="lower_frame_link"/>
    <child link="motor_s"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
  </joint>
  <joint name="joint_motor_h" type="fixed">
    <parent link="lower_frame_link"/>
    <child link="motor_h"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
  </joint>
  <joint name="joint_motor_v" type="fixed">
    <parent link="arm_link"/>
    <child link="motor_v"/>
    <origin xyz="-0.15 -1.425 0.14" rpy="-1.5708 0 0"/>
    <axis xyz="1 0 0"/>
  </joint>

  <link name="base"/>
  <joint name="base_link-base" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>
  <link name="flange"/>
  <joint name="flange_link-flange" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="flange_link"/>
    <child link="flange"/>
  </joint>
  <link name="tool0"/>
  <joint name="flange-tool0" type="fixed">
    <origin xyz="0 0 0" rpy="0 1.5708 0"/>
    <parent link="flange"/>
    <child link="tool0"/>
  </joint>
  
  <link name="world"/>
  <joint name="world_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
</robot>