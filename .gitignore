# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.so

# Packaging / build
build/
dist/
*.egg
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Test & lint caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/

# Logs
*.log
logs/

# ROS 2 / colcon (created when building the ros2_* packages in a workspace)
install/
log/
*.colcon
COLCON_IGNORE

# Docker: local machine-specific override (bind mounts, host paths) — keep it local.
# The committed full stack is docker-compose.full.yml.
docker-compose.override.yml

# Benchmark / run outputs
bench_*.json
*.out

# Model weights / HF cache (downloaded at runtime — never commit these)
.cache/
hf-cache/
*.safetensors
*.ckpt
*.pt
*.pth

# Secrets / local env
.env
.env.*
!.env.example

# IDE / editors
.idea/
.vscode/
*.swp
*.swo
*~

# OS junk
.DS_Store
Thumbs.db
